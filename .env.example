# =============================================================================
# Multi-Chain ZK Privacy Stack — Environment Configuration
# =============================================================================

# --- Private Keys (NEVER commit real keys) ---
DEPLOYER_PRIVATE_KEY=0x...
RELAYER_PRIVATE_KEY=0x...

# --- Avalanche ---
