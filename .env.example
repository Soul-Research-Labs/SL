# --- Cosmos EVM ---
EVMOS_TESTNET_RPC_URL=https://eth.bd.evmos.dev:8545
EVMOS_RPC_URL=https://eth.bd.evmos.org:8545

# --- Near EVM ---
AURORA_TESTNET_RPC_URL=https://testnet.aurora.dev
